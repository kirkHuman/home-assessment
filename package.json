{
  "name": "palcofirst-playwright",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "rm -rf allure-results allure-report && playwright test",
    "codegen": "playwright codegen",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "allure generate allure-results -o allure-report && allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.5.0",
    "allure": "^3.0.0",
    "allure-playwright": "^3.6.0",
    "typescript": "^5.7.0"
  }
}
